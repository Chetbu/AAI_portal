# Copy this file to .env and fill in real values
# cp .env.example .env

# Hostinger DNS API — used by Traefik for ACME DNS-01 challenge
# Get from: Hostinger control panel → API → Create API token
HOSTINGER_API_TOKEN=<your-hostinger-api-token>

# Azure AD / Microsoft Entra ID
AZURE_TENANT_ID=<your-azure-tenant-id>
AZURE_CLIENT_ID=<your-azure-client-id>
AZURE_CLIENT_SECRET=<your-azure-client-secret>

# traefik-forward-auth
# Cookie signing secret — generate with: openssl rand -hex 32
COOKIE_SECRET=<generated-hex-string>
# Comma-separated list of allowed email addresses
ALLOWED_EMAILS=you@company.com
